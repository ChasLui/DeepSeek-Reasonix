# =============================================================================
# Dependencies & build artifacts
# =============================================================================
node_modules/
dist/
coverage/
.stryker-tmp/
.turbo/
*.tsbuildinfo
*.cpuprofile

# Tauri desktop shell build artifacts.
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/src-tauri/binaries/

# Scratch entry regenerated each time scripts/bundle-codemirror.mjs runs.
scripts/.cm-entry.mjs

# VFS spike diagnostic report — regenerated by scripts/vfs-spike.ts, contains
# absolute machine paths (username + dir layout). Conclusions live in
# docs/plans/2026-05-20-just-bash-sandbox-borrow.md instead.
scripts/vfs-spike-report.md
benchmarks/real-world-cache/results/

# =============================================================================
# Environment & secrets
# =============================================================================
.env
.env.local

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Transcripts / sessions (jsonl)
# =============================================================================
transcripts/
sessions/
*.jsonl
!tests/**/*.jsonl
# Committed reference transcripts so readers can reasonix replay / diff
# the v0.1 bench results without an API key.
!benchmarks/tau-bench/transcripts/
!benchmarks/tau-bench/transcripts/*.jsonl

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
!.vscode/settings.json

# =============================================================================
# Local-only package manager artefacts
# =============================================================================
# Personal bun lockfile — project uses npm officially.
bun.lock
# Local portable Node/npm used for development on machines without npm.
.tools/
.npm-cache/

# =============================================================================
# Agent / tooling runtime state (per-user, never committed)
# =============================================================================
# Local-only Claude Code settings — personal overrides.
.claude/settings.local.json
# Per-user Reasonix state under .reasonix/ — committable team-level
# files (settings.json, skills/) stay tracked, but the user-private
# bits (semantic index, sessions, opt-out markers) never should.
.reasonix/semantic/
.reasonix/index/
.reasonix/sessions/
.reasonix/semantic-skip
# OpenWolf project runtime (daemon log, cron state, token ledger,
# memory, anatomy snapshots). Upstream openwolf treats the whole
# directory as per-machine state — do not commit.
# .wolf/
# Serena MCP local cache / project memories — per-user state.
# .serena/
# MAOS runtime cache.
.maos/

# =============================================================================
# Misc local references
# =============================================================================
# Design mock-up reference (local, not part of repo)
.design-ref/
.ccb/
.wolf/
docs/plans/*
bin/plan-lint.sh
bin/wolf-status.sh
tmp/
.claude/scheduled_tasks.lock
